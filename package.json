{
  "name": "job-monitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Frontend-only GitHub Actions PR & workflow dashboard",
  "homepage": "https://github.com/DevExpress/JavaJobMonitor",
  "author": {
    "name": "Xarlot",
    "email": "maksim.litvinov@devexpress.com"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/make-icon.mjs",
    "electron:dev": "npm run build && npm run icons && electron .",
    "electron:dist": "npm run build && npm run icons && electron-builder",
    "electron:publish": "npm run build && npm run icons && electron-builder --publish always"
  },
  "dependencies": {
    "@primer/octicons-react": "^19.28.1",
    "@primer/react": "^36.27.0",
    "@tanstack/react-table": "^8.21.3",
    "electron-updater": "^6.8.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^5.3.11",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^6.0.3",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
