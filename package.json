{
  "name": "job-monitor",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Frontend-only GitHub Actions PR & workflow dashboard",
  "homepage": "https://github.com/DevExpress/JavaJobMonitor",
  "author": {
    "name": "Xarlot",
    "email": "maksim.litvinov@devexpress.com"
  },
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "icons": "node scripts/make-icon.mjs",
    "electron:dev": "npm run build && npm run icons && electron .",
    "electron:dist": "npm run build && npm run icons && electron-builder",
    "electron:publish": "npm run build && npm run icons && electron-builder --publish always"
  },
  "dependencies": {
    "@primer/octicons-react": "^19.12.0",
    "@primer/react": "^36.27.0",
    "@tanstack/react-table": "^8.20.5",
    "electron-updater": "^6.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "styled-components": "^5.3.11",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@types/node": "^20.19.43",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/styled-components": "^5.1.34",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8",
    "fake-indexeddb": "^6.0.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.61.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
